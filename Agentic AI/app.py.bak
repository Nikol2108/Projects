def calculate_total_price(prices):
    total = 0
    for price in prices:
        if isinstance(price, (int, float)):  # Ensure price is a number
            total += price
    return total

if __name__ == "__main__":  # Correct the typo here
    orders = [10.5, 20.0, "oops", 5.0]
    print(f"Total price: {calculate_total_price(orders)}")